# ============================================================
# NOVATECH ADMIN FRONTEND — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase — get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key bypasses RLS — keep this SECRET, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin auth secret — used for signing session tokens
ADMIN_JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
